# Copiez ce fichier vers .env puis remplissez avec les valeurs de VOTRE projet Firebase
# (Console Firebase > Paramètres du projet > Vos applications > Config)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# URL de votre Cloud Function assistant (voir dossier functions/)
EXPO_PUBLIC_ASSISTANT_URL=https://us-central1-VOTRE-PROJET.cloudfunctions.net/assistant
